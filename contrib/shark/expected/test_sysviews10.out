CREATE TABLE sales_list (
    id        INT,
    product   VARCHAR(100),
    region_id INT,
    channel   VARCHAR(20),
    amount    NUMERIC
)
PARTITION BY LIST (region_id, channel) (
    PARTITION p_north_online  VALUES ((1, 'online'), (1, 'web')),
    PARTITION p_south_offline VALUES ((2, 'offline'), (2, 'store')),
    PARTITION p_other         VALUES (DEFAULT)
);
