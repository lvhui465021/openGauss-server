 ((((((SELECT t.name, t.object_id, t.principal_id, t.schema_id, t.parent_object_id, t.type, t.type_desc, t.create_date, t.modify_date, t.is_ms_shipped, t.is_published, t.is_schema_published FROM tables t UNION ALL SELECT c.relname AS name, c.oid AS object_id, CASE s.nspowner WHEN c.relowner THEN NULL::oid ELSE c.relowner END AS principal_id, s.oid AS schema_id, (0)::oid AS parent_object_id, 'SO'::character(2) AS type, 'SEQUENCE_OBJECT'::nvarchar2(60) AS type_desc, (o.ctime)::timestamp without time zone AS create_date, (o.mtime)::timestamp without time zone AS modify_date, (0)::bit(1) AS is_ms_shipped, (0)::bit(1) AS is_published, (0)::bit(1) AS is_schema_published FROM ((pg_class c JOIN pg_namespace s ON ((s.oid = c.relnamespace))) JOIN pg_object o ON ((o.object_oid = c.oid))) WHERE (((c.relkind = ANY (ARRAY['S'::"char", 'L'::"char"])) AND (s.nspname <> ALL (ARRAY['information_schema'::name, 'pg_catalog'::name, 'sys'::name, 'information_schema_tsql'::name]))) AND has_table_privilege(((quote_ident((s.nspname)::text) || '.'::text) || quote_ident((c.relname)::text)), 'SELECT'::text))) UNION ALL SELECT v.name, v.object_id, v.principal_id, v.schema_id, v.parent_object_id, v.type, v.type_desc, v.create_date, v.modify_date, v.is_ms_shipped, v.is_published, v.is_schema_published FROM views v) UNION ALL SELECT p.name, p.object_id, p.principal_id, p.schema_id, p.parent_object_id, p.type, p.type_desc, p.create_date, p.modify_date, p.is_ms_shipped, p.is_published, p.is_schema_published FROM procedures p) UNION ALL SELECT con.conname AS name, con.oid AS object_id, NULL::oid AS principal_id, con.connamespace AS schema_id, con.conrelid AS parent_object_id, (CASE con.contype WHEN 'c'::"char" THEN 'C'::text WHEN 'p'::"char" THEN 'PK'::text WHEN 'u'::"char" THEN 'UQ'::text WHEN 'f'::"char" THEN 'F'::text ELSE NULL::text END)::character(2) AS type, (CASE con.contype WHEN 'c'::"char" THEN 'CHECK_CONSTRAINT'::text WHEN 'p'::"char" THEN 'PRIMARY_KEY_CONSTRAINT'::text WHEN 'u'::"char" THEN 'UNIQUE_CONSTRAINT'::text WHEN 'f'::"char" THEN 'FOREIGN_KEY_CONSTRAINT'::text ELSE NULL::text END)::nvarchar2(60) AS type_desc, NULL::timestamp without time zone AS create_date, NULL::timestamp without time zone AS modify_date, (0)::bit(1) AS is_ms_shipped, (0)::bit(1) AS is_published, (0)::bit(1) AS is_schema_published FROM ((pg_constraint con JOIN pg_class c ON ((c.oid = con.conrelid))) JOIN pg_namespace s ON ((s.oid = con.connamespace))) WHERE (((con.contype = ANY (ARRAY['c'::"char", 'p'::"char", 'u'::"char", 'f'::"char"])) AND has_table_privilege(((quote_ident((s.nspname)::text) || '.'::text) || quote_ident((c.relname)::text)), 'SELECT'::text)) AND (s.nspname <> ALL (ARRAY['information_schema'::name, 'pg_catalog'::name, 'sys'::name, 'information_schema_tsql'::name])))) UNION ALL SELECT tg.tgname AS name, tg.oid AS object_id, NULL::oid AS principal_id, c.relnamespace AS schema_id, tg.tgrelid AS parent_object_id, 'TR'::character(2) AS type, 'SQL DML trigger'::nvarchar2(60) AS type_desc, (o.ctime)::timestamp without time zone AS create_date, (o.mtime)::timestamp without time zone AS modify_date, (0)::bit(1) AS is_ms_shipped, (0)::bit(1) AS is_published, (0)::bit(1) AS is_schema_published FROM (((pg_trigger tg JOIN pg_class c ON ((c.oid = tg.tgrelid))) JOIN pg_namespace s ON ((s.oid = c.relnamespace))) JOIN pg_object o ON ((o.object_oid = tg.oid))) WHERE (has_table_privilege(((quote_ident((s.nspname)::text) || '.'::text) || quote_ident((c.relname)::text)), 'SELECT'::text) AND (s.nspname <> ALL (ARRAY['information_schema'::name, 'pg_catalog'::name, 'sys'::name, 'information_schema_tsql'::name])))) UNION ALL SELECT NULL::name AS name, ad.oid AS object_id, NULL::oid AS principal_id, c.relnamespace AS schema_id, ad.adrelid AS parent_object_id, 'D'::character(2) AS type, 'DEFAULT'::nvarchar2(60) AS type_desc, (o.ctime)::timestamp without time zone AS create_date, (o.mtime)::timestamp without time zone AS modify_date, (0)::bit(1) AS is_ms_shipped, (0)::bit(1) AS is_published, (0)::bit(1) AS is_schema_published FROM (((pg_attrdef ad JOIN pg_class c ON ((c.oid = ad.adrelid))) JOIN pg_namespace s ON ((s.oid = c.relnamespace))) JOIN pg_object o ON ((o.object_oid = ad.adrelid))) WHERE (has_table_privilege(((quote_ident((s.nspname)::text) || '.'::text) || quote_ident((c.relname)::text)), 'SELECT'::text) AND (s.nspname <> ALL (ARRAY['information_schema'::name, 'pg_catalog'::name, 'sys'::name, 'information_schema_tsql'::name])))) UNION ALL SELECT syn.synname AS name, syn.oid AS object_id, CASE s.nspowner WHEN syn.synowner THEN NULL::oid ELSE syn.synowner END AS principal_id, syn.synnamespace AS schema_id, (0)::oid AS parent_object_id, 'SN'::character(2) AS type, 'Synonym'::nvarchar2(60) AS type_desc, NULL::timestamp without time zone AS create_date, NULL::timestamp without time zone AS modify_date, (0)::bit(1) AS is_ms_shipped, (0)::bit(1) AS is_published, (0)::bit(1) AS is_schema_published FROM (pg_synonym syn JOIN pg_namespace s ON ((s.oid = syn.synnamespace))) WHERE (s.nspname <> ALL (ARRAY['information_schema'::name, 'pg_catalog'::name, 'sys'::name, 'information_schema_tsql'::name]));
