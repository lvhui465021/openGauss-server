 CREATE OR REPLACE FUNCTION sharksysfunc.calculate_total_grade()+
  RETURNS numeric                                               +
  LANGUAGE plpgsql                                              +
  NOT FENCED NOT SHIPPABLE                                      +
 AS $function$                                                  +
 DECLARE                                                        +
     total_grade DECIMAL(10, 2) := 0;                           +
 BEGIN                                                          +
     SELECT SUM(grade) INTO total_grade FROM students;          +
     RETURN total_grade;                                        +
 END;                                                           +
 $function$;                                                    +
 
(1 row)

